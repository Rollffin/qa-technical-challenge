{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["src/**/*", "step-definitions/**/*"],
  "exclude": ["node_modules", "dist"]
}
